# GPS - Sistema de Gestión Documental
# Copia este archivo como .env y completa los valores

# Base de datos
DB_PASSWORD=cambia_esto_por_password_seguro

# JWT
JWT_SECRET=cambia_esto_por_clave_secreta_larga_y_segura

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=cambia_esto_por_password_minio_seguro

# URL pública del servidor (para URLs de descarga de archivos)
# Debe ser la IP o dominio del servidor sin http://
MINIO_PUBLIC_ENDPOINT=IP_O_DOMINIO_DEL_SERVIDOR
MINIO_PUBLIC_PORT=8031

# Docker Hub (solo para CI/CD, no necesario en el servidor)
DOCKERHUB_USERNAME=tu_usuario_dockerhub

# Configuración de Correo Real (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_contraseña_de_aplicación_o_password
SMTP_FROM="GPS Seguridad" <tu_correo@gmail.com>